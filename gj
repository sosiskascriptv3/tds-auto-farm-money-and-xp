    btn.Position, btn.Size = pos, UDim2.new(0, 240, 0, 40)
    btn.Font, btn.Text, btn.TextColor3, btn.TextSize = Enum.Font.GothamBold, text, Color3.new(1, 1, 1), 18
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
end

